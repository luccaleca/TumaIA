# Se 4000 estiver ocupada (outro projeto / processo antigo), use outra, ex.: 4040
PORT=4000

# Chamadas vindas do N8N (header X-Internal-Secret ou Authorization: Bearer)
INTERNAL_WEBHOOK_SECRET=

# Supabase (service role no backend — nunca no browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Postgres (opcional, para conexao SQL direta)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.sjffdhzjomdpikrvibuj.supabase.co:5432/postgres

# Google Gemini (texto / multimodal; imagem conforme modelo disponível na sua conta)
GOOGLE_AI_API_KEY=
# Opcional: limite diário local para acompanhar "quanto ainda resta"
# GEMINI_DAILY_TOKEN_BUDGET=200000

# Opcional: validar assinatura de webhooks do Meta (WhatsApp / Instagram)
# META_APP_SECRET=
